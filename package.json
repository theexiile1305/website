    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "12.7.4",
    "gray-matter": "4.0.3",
    "next": "16.2.3",
    "next-mdx-remote": "5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-security": "3.0.1",
    "prettier": "3.5.3",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  },
  "pnpm": {
